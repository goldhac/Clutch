# Copy to .env.local and fill in. .env.local is gitignored — never commit secrets.

# ── LLM engine (Step 6) ──────────────────────────────────────────────
# Default provider: Google Gemini (2.5 Pro for ranking, 2.5 Flash for cheap meta).
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: also keep Anthropic as fallback for the trust-layer step if
# Gemini ever invents citations. Leave blank to disable.
# Get from https://console.anthropic.com/ → API Keys
ANTHROPIC_API_KEY=

# Override the default model id (LLMClient is provider-agnostic).
# Examples: "gemini-2.5-pro" | "gemini-2.5-flash" | "claude-sonnet-4-5"
CRAMSHEET_MODEL=gemini-2.5-pro


# ── Supabase (Step 9) ────────────────────────────────────────────────
# Get from your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=


# ── Stripe (Step 10) ─────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/test/apikeys (test mode is fine to start)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Price IDs (create products in the Stripe dashboard, paste IDs here)
STRIPE_PRICE_SINGLE=
STRIPE_PRICE_3PACK=
STRIPE_PRICE_SPRINT=


# ── App ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
