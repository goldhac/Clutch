# Copy to .env.local and fill in. .env.local is gitignored — never commit secrets.

# ── LLM engine (Step 6) ──────────────────────────────────────────────
# Get from https://console.anthropic.com/ → API Keys
# Set a spend limit ($10–20) on the same page as cheap insurance.
ANTHROPIC_API_KEY=

# Optional override; leave unset to use api.anthropic.com
# ANTHROPIC_BASE_URL=

# Default model for the engine. Sonnet is the v1 default — see docs/05-BUILD-PLAN.md §8.
# Override per-task in code (LLMClient is provider-agnostic).
CRAMSHEET_MODEL=claude-sonnet-4-5


# ── Supabase (Step 9) ────────────────────────────────────────────────
# Get from your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=


# ── Stripe (Step 10) ─────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/test/apikeys (test mode is fine to start)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Price IDs (create products in the Stripe dashboard, paste IDs here)
STRIPE_PRICE_SINGLE=
STRIPE_PRICE_3PACK=
STRIPE_PRICE_SPRINT=


# ── App ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
