# Match .gitignore mostly + a few container-specific excludes.
.git
.gitignore
.github

node_modules
.next
out
build
dist

# Local dev artifacts
.env
.env.local
.env*.local
*.log
.DS_Store

# Private reference materials (already gitignored; never put in image)
reference/
_private/

# Editor + OS
.vscode
.idea
Thumbs.db

# Build-time-only excludes — samples/ is imported by /sheet so it MUST
# ship. scripts/ + tests/ + docs/ are not imported at runtime.
scripts/
tests/
docs/

# Don't include any pre-built PDFs
*.pdf

# Don't ship the playwright local browser cache; image already has it
.cache
